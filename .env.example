# OpenRouter (recommended for the free models in this project)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Default model — nemotron is more stable than gpt-oss-120b:free on OpenRouter
RESEARCH_MODEL=poolside/laguna-m.1:free

# Or use OpenAI directly instead
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional — only needed for the email delivery step
GMAIL_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
RECIPIENT_EMAIL=recipient@example.com

# Aliases also supported:
# EMAIL_FROM=you@gmail.com
# EMAIL_PASSWORD=your16charapppassword
# EMAIL_TO=recipient@example.com
